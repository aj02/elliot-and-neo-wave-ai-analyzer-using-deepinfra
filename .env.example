# wave-agent — environment configuration
# Copy this file to .env and fill in the values for the provider you choose.

# ---- LLM provider selection ----
# Pick one. The wave-rule agents (per-timeframe) use the "fast" tier and the
# synthesis agent uses the "smart" tier; on Anthropic this maps to Haiku/Sonnet,
# on OpenAI to gpt-4o-mini/gpt-4o, and on DeepInfra/DeepSeek both default to
# the same DeepSeek model (cheap enough that splitting fast/smart is overkill).
LLM_PROVIDER=anthropic

# ---- Anthropic (default) ----
ANTHROPIC_API_KEY=

# ---- OpenAI fallback ----
OPENAI_API_KEY=

# ---- DeepInfra (DeepSeek, Kimi, Llama, Mistral, GLM — anything they host) ----
# Sign up at https://deepinfra.com → Account → API Keys.
DEEPINFRA_API_KEY=
# Override only if DeepInfra changes their endpoint or you front it with a proxy.
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
# The exact model name comes from https://deepinfra.com/models — copy it verbatim.
# Some examples:
#   deepseek-ai/DeepSeek-V3.1
#   moonshotai/Kimi-K2-Instruct
#   moonshotai/Kimi-K2-Instruct-0905
#   meta-llama/Llama-3.3-70B-Instruct
# Same model is used for both fast and smart tiers by default; override either
# if you want a cheaper per-timeframe model + a smarter synthesis model.
# DEEPINFRA_MODEL_FAST=deepseek-ai/DeepSeek-V3.1
# DEEPINFRA_MODEL_SMART=deepseek-ai/DeepSeek-V3.1
# Pricing per 1M tokens (USD). Adjust if DeepInfra changes their rates or you
# switch to a model with different rates — the cost cap reads these.
# DEEPINFRA_INPUT_PRICE_PER_MTOK=0.27
# DEEPINFRA_OUTPUT_PRICE_PER_MTOK=1.10

# ---- Postgres ----
POSTGRES_USER=waveagent
POSTGRES_PASSWORD=waveagent
POSTGRES_DB=waveagent
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Service ports ----
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ---- Frontend public URLs (baked into the Next.js build) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ---- Runtime ----
LOG_LEVEL=INFO
ENVIRONMENT=development

# Hard cap on estimated LLM spend per analysis run, in USD.
# Runs that exceed this estimate are rejected before any LLM call is made.
MAX_RUN_COST_USD=0.50
